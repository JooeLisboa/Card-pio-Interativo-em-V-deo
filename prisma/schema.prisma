generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
}

model Restaurant {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  description     String
  logoUrl         String?
  primaryColor    String    @default("#7C3F12")
  secondaryColor  String    @default("#F59E0B")
  phoneNumber     String?
  whatsappNumber  String
  serviceLabel    String    @default("Entrega e retirada disponíveis")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  categories      Category[]
  dishes          Dish[]
  tables          Table[]
  users           User[]

  @@index([slug])
}

model Category {
  id           String      @id @default(cuid())
  restaurantId String
  name         String
  slug         String
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dishes       Dish[]

  @@unique([restaurantId, slug])
  @@index([restaurantId, sortOrder])
}

model Dish {
  id           String           @id @default(cuid())
  restaurantId String
  categoryId   String
  name         String
  slug         String
  description  String
  price        Decimal          @db.Decimal(10, 2)
  imageUrl     String?
  youtubeUrl   String?
  isAvailable  Boolean          @default(true)
  isFeatured   Boolean          @default(false)
  sortOrder    Int              @default(0)
  viewsCount   Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category     Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  viewEvents   DishViewEvent[]

  @@unique([restaurantId, slug])
  @@index([restaurantId, categoryId, sortOrder])
  @@index([restaurantId, viewsCount])
}

model Table {
  id           String           @id @default(cuid())
  restaurantId String
  number       Int
  code         String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  viewEvents   DishViewEvent[]

  @@unique([restaurantId, number])
  @@unique([restaurantId, code])
}

model DishViewEvent {
  id        String   @id @default(cuid())
  dishId     String
  tableId    String?
  viewedAt   DateTime @default(now())
  dish       Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  table      Table?   @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([dishId, viewedAt])
  @@index([tableId, viewedAt])
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(ADMIN)
  restaurantId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
}
